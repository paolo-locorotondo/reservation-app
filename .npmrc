# pnpm + Vercel Functions: la compilazione TypeScript delle Serverless
# Functions di Vercel non risolve i tipi attraverso i symlink di pnpm
# (node_modules/@prisma/client -> node_modules/.pnpm/@prisma+client@.../...).
# Con node-linker=hoisted pnpm crea un node_modules flat (stile npm), così
# il client Prisma generato da `prisma generate` viene visto correttamente.
node-linker=hoisted

# shamefully-hoist appiattisce anche le sub-dipendenze al top-level di
# node_modules ed elimina la cartella `.pnpm/` con i suoi symlink interni.
# Necessario su Vercel: senza questo, il pacchettizzatore delle Serverless
# Functions vede ancora link simbolici e fallisce con "framework produced
# an invalid deployment package... symlinked directories".
shamefully-hoist=true
