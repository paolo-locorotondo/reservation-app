// Prisma schema — reservation-app
// See plan: ../../../C:/Users/PAOLOLOCOROTONDO/.claude/plans/twinkling-humming-whisper.md

generator client {
  provider      = "prisma-client-js"
  // "native" per lo sviluppo locale (Windows/macOS).
  // "rhel-openssl-3.0.x"   → Vercel (Amazon Linux derivato RHEL).
  // "debian-openssl-3.0.x" → Docker image node:20-bookworm-slim usata per Code Engine / IBM Cloud.
  // Senza i target Linux, in produzione Prisma fallisce con
  // "Query engine binary for current platform not found".
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Usato da `prisma migrate` e `prisma db push`. Su Supabase punta al
  // Session pooler (porta 5432) o alla Direct connection; NON al Transaction
  // pooler (6543), che non supporta advisory lock e fa hangare la migrate.
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum SpotType {
  PARKING
  DESK
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  displayName  String
  role         Role          @default(USER)
  accounts     Account[]
  reservations Reservation[]
  closures     Closure[]     // Audit: chi ha creato il blocco
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Identità federata: collega un utente a uno o più provider IdP (Google, Entra, …).
// Lookup al login: findUnique per (provider, providerSub); se assente, fallback per email
// e link del nuovo Account allo User esistente.
model Account {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // es. "google" | "entra"
  providerSub String   // identificatore stabile del provider (sub/oid)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSub])
  @@index([userId])
}

model Site {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  floors   Floor[]
  closures Closure[]
}

model Floor {
  id     String @id @default(cuid())
  siteId String
  name   String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  zones  Zone[]
  spots  Spot[]

  @@unique([siteId, name])
}

model Zone {
  id      String @id @default(cuid())
  floorId String
  name    String
  floor   Floor  @relation(fields: [floorId], references: [id], onDelete: Cascade)
  spots   Spot[]

  @@unique([floorId, name])
}

model Spot {
  id           String        @id @default(cuid())
  code         String
  type         SpotType
  floorId      String
  zoneId       String?
  active       Boolean       @default(true)
  floor        Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zone         Zone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  reservations Reservation[]

  @@unique([floorId, code])
  @@index([type, active])
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  spotId    String
  // Denormalizzazione di Spot.type su Reservation: serve come campo del
  // partial unique index `(userId, date, spotType) WHERE status='ACTIVE'` che
  // garantisce a livello DB la regola "max 1 ACTIVE per utente/giorno/tipo".
  // Senza denormalizzazione l'index dovrebbe essere su una colonna join e non
  // è esprimibile in Postgres. Il valore è stabile (un posto non cambia
  // tipo) e popolato in create() leggendolo da Spot.
  spotType  SpotType
  date      DateTime          @db.Date
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  // Aggiornato automaticamente da Prisma a ogni `update`. Utile per tracciare
  // QUANDO una prenotazione è stata cancellata (cancel = update di status):
  // basta filtrare per `status='CANCELLED'` e leggere `updatedAt`.
  // `@default(now())` serve solo per backfillare le righe esistenti al
  // momento dell'ALTER TABLE: per i nuovi record `@updatedAt` lo sovrascrive
  // ad ogni create/update.
  updatedAt DateTime          @default(now()) @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot      Spot              @relation(fields: [spotId], references: [id], onDelete: Cascade)

  // Due partial unique index gestiti via SQL (Prisma non li modella):
  //  - `Reservation_spotId_date_active_key` (migration reservation_active_partial_unique):
  //     "max 1 ACTIVE per spot/giorno"
  //  - `Reservation_userId_date_spotType_active_key` (migration in arrivo):
  //     "max 1 ACTIVE per utente/giorno/tipo"
  // Entrambi `WHERE status='ACTIVE'` per non impedire più CANCELLED storiche
  // sulla stessa slot.
  @@index([userId, date])
  @@index([date, status])
}

// Giorni bloccati (festività, chiusure di sede, manutenzioni). Le prenotazioni
// non possono essere CREATE per giorni che matchano una Closure. Le esistenti
// non vengono invalidate retroattivamente — l'admin le cancella manualmente
// se serve.
//
// Match logic (in ReservationsService.create):
//   spot blocked := exists Closure C where
//     C.date = dto.date
//     AND (C.siteId IS NULL OR C.siteId = spot.floor.siteId)
//     AND (C.spotType IS NULL OR C.spotType = spot.type)
//
// Niente @@unique su (date, siteId, spotType): permettiamo closure
// sovrapposte (es. globale "Natale" + locale "Lavori a Bari").
model Closure {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  // null = blocca TUTTE le sedi
  siteId          String?
  // null = blocca ENTRAMBI i tipi (parking + desk)
  spotType        SpotType?
  reason          String
  createdAt       DateTime @default(now())
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  site            Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([siteId, date])
}
