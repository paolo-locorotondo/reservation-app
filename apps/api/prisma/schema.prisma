// Prisma schema — reservation-app
// See plan: ../../../C:/Users/PAOLOLOCOROTONDO/.claude/plans/twinkling-humming-whisper.md

generator client {
  provider      = "prisma-client-js"
  // "native" per lo sviluppo locale (Windows/macOS), "rhel-openssl-3.0.x" per il
  // runtime Linux di Vercel (Node 20). Senza questo target, in produzione
  // Prisma fallisce con "Query engine binary for current platform not found".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Usato da `prisma migrate` e `prisma db push`. Su Supabase punta al
  // Session pooler (porta 5432) o alla Direct connection; NON al Transaction
  // pooler (6543), che non supporta advisory lock e fa hangare la migrate.
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum SpotType {
  PARKING
  DESK
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  displayName  String
  role         Role          @default(USER)
  accounts     Account[]
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Identità federata: collega un utente a uno o più provider IdP (Google, Entra, …).
// Lookup al login: findUnique per (provider, providerSub); se assente, fallback per email
// e link del nuovo Account allo User esistente.
model Account {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // es. "google" | "entra"
  providerSub String   // identificatore stabile del provider (sub/oid)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSub])
  @@index([userId])
}

model Site {
  id     String  @id @default(cuid())
  code   String  @unique
  name   String
  floors Floor[]
}

model Floor {
  id     String @id @default(cuid())
  siteId String
  name   String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  zones  Zone[]
  spots  Spot[]

  @@unique([siteId, name])
}

model Zone {
  id      String @id @default(cuid())
  floorId String
  name    String
  floor   Floor  @relation(fields: [floorId], references: [id], onDelete: Cascade)
  spots   Spot[]

  @@unique([floorId, name])
}

model Spot {
  id           String        @id @default(cuid())
  code         String
  type         SpotType
  floorId      String
  zoneId       String?
  active       Boolean       @default(true)
  floor        Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zone         Zone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  reservations Reservation[]

  @@unique([floorId, code])
  @@index([type, active])
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  spotId    String
  date      DateTime          @db.Date
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot      Spot              @relation(fields: [spotId], references: [id], onDelete: Cascade)

  // Unicità "una sola ACTIVE per spot+giorno" è gestita da un partial unique
  // index in SQL (vedi migration `reservation_active_partial_unique`):
  // CREATE UNIQUE INDEX ... ON "Reservation"("spotId","date") WHERE status='ACTIVE'
  // Un @@unique pieno su (spotId,date,status) impedirebbe il secondo cancel
  // dello stesso spot/giorno (collisione su CANCELLED già storica).
  @@index([userId, date])
  @@index([date, status])
}
