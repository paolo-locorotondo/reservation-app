# =============================================================================
# Reservation App — variabili d'ambiente di esempio
# Copia questo file in `.env` e adatta i valori al tuo setup locale.
#   cp .env.example .env
#
# Le variabili sono raggruppate per CONSUMATORE:
#   [infra]    Database / container Postgres (Docker Compose) + Prisma
#   [web+api]  condivise tra i due processi
#   [api]      backend NestJS              → apps/api
#   [web]      frontend Next.js / NextAuth → apps/web
# Su Vercel: le [api] vanno sul progetto API, le [web] sul progetto web, le
# [infra]/[web+api] su entrambi dove servono (vedi DEPLOY.md).
# =============================================================================



# -----------------------------------------------------------------------------
# [infra] Database — container Postgres (Docker Compose) + connessioni Prisma
#   POSTGRES_*        → consumati dal container Postgres del compose
#   DATABASE_URL      → runtime API (Prisma client)
#   DIRECT_URL        → `prisma migrate` (vedi nota pooler per Supabase)
# -----------------------------------------------------------------------------

# Locale (Docker Compose):
DATABASE_URL=postgresql://reservation:reservation@localhost:5432/reservation?schema=public
DIRECT_URL=postgresql://reservation:reservation@localhost:5432/reservation?schema=public
POSTGRES_USER=reservation
POSTGRES_PASSWORD=reservation
POSTGRES_DB=reservation

# Supabase (Prod):
#POSTGRES_USER=<insert db user>
## Nota: la password va URL-encoded se contiene caratteri speciali (@ : / ? # & %).
#POSTGRES_PASSWORD=<insert db password>
#POSTGRES_DB=<insert db name>
## Runtime API → Transaction pooler (PgBouncer, porta 6543, pgbouncer=true)
#DATABASE_URL="<insert db url Transaction pooler>"
## Migrate → Session pooler (porta 5432) — NON usare 6543 qui o `migrate` si blocca
#DIRECT_URL="<insert db url Session pooler>"



# -----------------------------------------------------------------------------
# [web+api] Segreto condiviso
# -----------------------------------------------------------------------------

# Genera un secret robusto:  openssl rand -base64 32
# (oppure: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# IMPORTANTE: lo STESSO valore deve stare su web e api — il web (NextAuth) firma
# il JWT che il proxy BFF inoltra, l'api lo verifica con questo segreto.
NEXTAUTH_SECRET=replace-me-with-generated-secret



# -----------------------------------------------------------------------------
# [api] Backend NestJS (apps/api)
# -----------------------------------------------------------------------------

# Porta su cui l'API ascolta in locale.
PORT=3001

# --- Regole business ---

# Massimo numero di giorni nel futuro per cui un utente può prenotare. Validato
# lato API in create()/availability. DEVE essere allineato a
# NEXT_PUBLIC_MAX_DAYS_AHEAD (sezione [web]). Default codice: 30.
MAX_DAYS_AHEAD=7

# Limiti delle list view admin/manager (fallback nel codice tra parentesi).
# Se il dataset filtrato supera il limite, la risposta è troncata + banner UI.
ADMIN_RESERVATIONS_LIST_LIMIT=3000   # default codice: 500

# Tetto di inserimenti per il caricamento massivo (N utenti × M giorni).
BULK_RESERVATIONS_MAX_INSERTS=5000   # default codice: 5000

# Limite della lista in /my-reservations.
MY_RESERVATIONS_LIST_LIMIT=100       # default codice: 100



# -----------------------------------------------------------------------------
# [web] Frontend Next.js / NextAuth (apps/web)
# -----------------------------------------------------------------------------

# URL interno con cui il web (Next.js) chiama l'API. In locale è localhost; in
# docker-compose sarebbe http://api:3001 (se aggiungeremo il servizio api).
API_INTERNAL_URL=http://localhost:3001

# Base URL pubblica dell'app web. In locale localhost:3000; su Vercel l'URL del
# deployment (https://<app>.vercel.app). NextAuth ci costruisce i callback URL.
NEXTAUTH_URL=http://localhost:3000

# --- Auth provider: Google OAuth ---
# OAuth Client su https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
# (vuoto = bottone "Accedi con Google" nascosto nella pagina di login)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# --- Auth provider: IBM SSO w3id ---
# App su https://w3.ibm.com/security/sso-provisioner
# Configurato con:
# Identity Provider: w3id
# SSO Protocol: OIDC
# Tenant: Preprod
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/ibmsso
# (vuoto = bottone "Accedi con IBM w3 SSO" nascosto nella pagina di login)
AUTH_IBMSSO_ID=replace-with-ibm-sso-client-id
AUTH_IBMSSO_SECRET=replace-with-ibm-sso-client-secret

# --- Auth provider: Microsoft Entra ID (Azure AD) — opzionale, per il futuro ---
# Quando avrai un tenant Entra, popola questi 3 valori; al riavvio il provider
# verrà attivato in NextAuth a fianco degli altri.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# --- Ruoli (mapping email → ruolo al login) ---

# Calcolo ruolo: ADMIN (ADMIN_EMAILS) > MANAGER (claim w3id ibmEdIsManager="Y"
# OPPURE MANAGER_EMAILS) > USER. Email separate da virgola, senza spazi.
# Es: ADMIN_EMAILS=mario.rossi@gmail.com,dev@example.com
ADMIN_EMAILS=

# MANAGER_EMAILS forza il ruolo MANAGER anche senza il claim w3id: utile per
# test locale (il proprio account w3id ha ibmEdIsManager="N") e come escape
# hatch a regime.
MANAGER_EMAILS=

# Mirror lato client di MAX_DAYS_AHEAD (Next espone al browser solo le var con
# prefisso NEXT_PUBLIC_). Letto da calendario/DatePicker. Tieni lo stesso
# valore di MAX_DAYS_AHEAD nella sezione [api].
NEXT_PUBLIC_MAX_DAYS_AHEAD=7

# Maintenance mode: "1" = il middleware serve a OGNI richiesta (pagine + proxy
# API) una pagina 503 "in manutenzione", mettendo di fatto il sito offline;
# qualsiasi altro valore / assente = funzionamento normale. Letto al boot Edge,
# quindi per accenderlo/spegnerlo su Vercel serve cambiare la var + redeploy.
MAINTENANCE_MODE=0
