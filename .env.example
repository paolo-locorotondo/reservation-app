# =============================================================================
# Reservation App — variabili d'ambiente di esempio
# Copia questo file in `.env` e adatta i valori al tuo setup locale.
#   cp .env.example .env
# =============================================================================

# --- Database (usato sia da Postgres in compose, sia da Prisma) ---
POSTGRES_USER=reservation
POSTGRES_PASSWORD=reservation
POSTGRES_DB=reservation

# Locale (Docker Compose):
DATABASE_URL=postgresql://reservation:reservation@localhost:5432/reservation?schema=public
DIRECT_URL=postgresql://reservation:reservation@localhost:5432/reservation?schema=public

# Supabase (esempio — sostituisci <ref>, <region>, <password>):
#   Runtime API → Transaction pooler (PgBouncer, porta 6543, pgbouncer=true)
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   Migrate    → Session pooler (porta 5432) — NON usare 6543 qui o `migrate` si blocca
# DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Nota: la password va URL-encoded se contiene caratteri speciali (@ : / ? # & %).

# --- API NestJS ---
PORT=3001
# URL interno con cui il web (Next.js) chiama l'API. In sviluppo locale è localhost.
# In docker-compose sarebbe http://api:3001 (se aggiungeremo il servizio api al compose).
API_INTERNAL_URL=http://localhost:3001

# --- Regole business ---
# Massimo numero di giorni nel futuro per cui si può prenotare (e per cui il
# calendario mostra disponibilità). Letto sia dall'API (validazioni) sia dal web
# (bottoni prev/next del calendario). Se cambi questo valore, aggiorna ENTRAMBE
# le variabili sotto al valore desiderato. Default: 30.
MAX_DAYS_AHEAD=30
# Variante esposta al frontend (Next.js richiede prefisso NEXT_PUBLIC_ per le
# env var lette nel client browser). Mantieni in pari con MAX_DAYS_AHEAD sopra.
NEXT_PUBLIC_MAX_DAYS_AHEAD=30

# --- Next.js / NextAuth ---
# Genera un secret robusto:  openssl rand -base64 32
# (oppure: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# IMPORTANTE: lo stesso valore è usato dall'API per verificare il JWT che il BFF inoltra.
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (provider attivo in dev) ---
# Crea un OAuth Client su https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Ruoli (mapping email → ADMIN per lo sviluppo locale) ---
# Lista email che ricevono il ruolo ADMIN al login (separate da virgola, no spazi).
# Es: ADMIN_EMAILS=mario.rossi@gmail.com,dev@example.com
ADMIN_EMAILS=

# --- Microsoft Entra ID (Azure AD) — provider opzionale per produzione, configurabile in seguito ---
# Quando avrai un tenant Entra, popola questi 3 valori; al riavvio il provider Entra
# verrà attivato in NextAuth a fianco di Google.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
