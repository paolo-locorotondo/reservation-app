# =============================================================================
# Reservation App — variabili d'ambiente di esempio
# Copia questo file in `.env` e adatta i valori al tuo setup locale.
#   cp .env.example .env
# =============================================================================

# --- Database (usato sia da Postgres in compose, sia da Prisma) ---
POSTGRES_USER=reservation
POSTGRES_PASSWORD=reservation
POSTGRES_DB=reservation
DATABASE_URL=postgresql://reservation:reservation@localhost:5432/reservation?schema=public

# --- API NestJS ---
PORT=3001
# URL interno con cui il web (Next.js) chiama l'API. In sviluppo locale è localhost.
# In docker-compose sarebbe http://api:3001 (se aggiungeremo il servizio api al compose).
API_INTERNAL_URL=http://localhost:3001

# --- Next.js / NextAuth (popolare in Sprint 1) ---
# Genera un secret con:  openssl rand -base64 32   (oppure  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXTAUTH_SECRET=replace-me-in-sprint-1
NEXTAUTH_URL=http://localhost:3000

# --- Microsoft Entra ID (Azure AD) — popolare in Sprint 1 dopo aver creato il tenant di test ---
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
