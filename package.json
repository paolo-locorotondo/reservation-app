{
  "name": "reservation-app",
  "version": "0.1.0",
  "private": true,
  "description": "Prenotazione posti auto e scrivanie - monorepo (NestJS + Next.js)",
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @reservation/api prisma migrate dev",
    "db:seed": "pnpm --filter @reservation/api prisma db seed",
    "db:reset": "pnpm --filter @reservation/api prisma migrate reset --force"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
